# ── App mode ─────────────────────────────────────────────────────────────────
# Set to "false" when you have Supabase credentials ready
# Set to "true" (default) to run with mock data - no Supabase needed
NEXT_PUBLIC_USE_MOCK_DATA=true

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── OpenAI (OCR parsing) ──────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
# Without this, OCR route returns mock parsed data (useful for dev)
OPENAI_API_KEY=sk-...

# ── Google Vision (OCR image processing) ─────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Vision API → Credentials
# Without this, OCR route skips Vision and passes raw text to GPT-4o
GOOGLE_VISION_API_KEY=your-vision-api-key

# ── Google Calendar OAuth ─────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# For Replit: https://YOUR-REPL.repl.co/api/auth/google/callback
# For Vercel: https://your-app.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── App config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TIMEZONE=Africa/Johannesburg
